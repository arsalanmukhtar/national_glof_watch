# ---------------------------------------------------------------------------
# VM connection settings consumed by `scripts/deploy/*.sh`.
#
# Copy to .env.deploy and fill in. .env.deploy is gitignored.
# ---------------------------------------------------------------------------

# Public IP or DNS name of the VM you're deploying to.
VM_HOST=

# SSH user with sudo / docker access on the VM.
VM_USER=

# Absolute path on the VM where the project checkout lives. The
# vm-deploy.sh script `cd`s here before running compose commands.
VM_PATH=/opt/glof/national_glof_watch

# Optional: path to the SSH private key to use. Leave blank to fall
# back on the user's default ssh-agent / ~/.ssh/config setup.
VM_SSH_KEY=

# SSH port. Defaults to 22 when blank.
VM_PORT=22

# Git remote to use when promoting main → prod. The promote script
# `git push <remote> prod` against this name. `origin` is the usual
# value; override only if your VM has a different remote name.
GIT_REMOTE=origin
