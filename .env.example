# Mapbox public access token (pk.*) — required for the basemap
VITE_MAPBOX_TOKEN=
# Federal GeoServer base URL hosting most WFS layers
VITE_GEOSERVER_BASE_URL=
# Provincial GeoServer base URL (separate host for some boundary layers)
VITE_GEOSERVER_PROVINCIAL_URL=
# Initial map center longitude
VITE_DEFAULT_MAP_CENTER_LNG=
# Initial map center latitude
VITE_DEFAULT_MAP_CENTER_LAT=
# Initial map zoom level
VITE_DEFAULT_MAP_ZOOM=
# Initial map pitch in degrees
VITE_DEFAULT_MAP_PITCH=

# ── Backend ──────────────────────────────────────────────────
# Express port (Vite proxies /api to this)
PORT=3001
# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=glof
PG_USER=postgres
PG_PASSWORD=
# Value-fetch cadence in minutes (default 10)
STORE_INTERVAL_MIN=10
# Threshold (entryCfgs) sweep cadence in days (default 30)
THRESHOLD_INTERVAL_DAYS=30

# ── Datascape v3 API (PMD element catalog, readings, thresholds) ──
DATASCAPE_BASE=http://115.186.56.181/datascapea
DATASCAPE_USER=DatascapeUser
DATASCAPE_PASSWORD=
DATASCAPE_CLIENT_ID=GenericClient
DATASCAPE_CLIENT_INSTANCE=12345
