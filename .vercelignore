# Anything Vercel doesn't need for the frontend SPA build. Keeps the
# upload size down (Vercel charges by build minutes + bandwidth) and
# makes the deploy log cleaner. Mirrors .dockerignore loosely but
# tuned for "just the React app + its assets" output.

# Backend + infra
server
Dockerfile.backend
Dockerfile.frontend
docker-compose.yml
docker-compose.prod.yml
docker
.dockerignore

# Deploy + DB tooling
scripts/db
scripts/deploy
scripts/python
backups
*.sql.bak

# Local dev artefacts.
# Patterns starting with "/" are anchored to the repo root, so e.g.
# "/Alerts" excludes the legacy Alerts/ folder at root WITHOUT also
# nuking src/assets/images/alerts/ on case-insensitive matchers.
# (We hit exactly that bug — Vercel folded "Alerts" to "alerts" and
# stripped every alert JPEG out of the upload, which broke the
# Rollup resolve in src/assets/index.js.)
.venv
venv
__pycache__
/data
/Maps
/Alerts
/legacy
/docs

# Env files (Vercel reads from its own dashboard env, not from the repo)
.env
.env.local
.env.*.local
.env.deploy
.env.deploy.example

# OS / editor
.DS_Store
Thumbs.db
.idea
.vscode
