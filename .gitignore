# Dependencies
node_modules/

# Build output
dist/
.vite/

# Env (keep .env.example tracked)
.env
.env.local
.env.*.local
.env.deploy

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Coverage
coverage/
data/geojsons/

# DB dumps — local snapshots, not for git. Keep `scripts/db/*` tracked.
backups/
*.sql.bak

# SSH keys — should live under ~/.ssh, never in the repo. Belt-and-
# suspenders in case someone runs ssh-keygen with a relative filename.
id_ed25519*
id_rsa*
*ssh_key*
*.pem

# Python (auxiliary scripts under scripts/python/)
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/